{
  "expo": {
    "name": "Cue",
    "slug": "cue",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cue",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1f14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.joenazzaro.cue",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1f14"
      },
      "package": "com.joenazzaro.cue"
    },
    "extra": {
      "eas": {
        "projectId": "9379019c-c094-49d1-9da0-749796fd214a"
      }
    },
    "plugins": [
      "expo-router"
    ]
  }
}
